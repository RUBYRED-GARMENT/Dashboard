<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>RUBYRED Pro Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Roboto+Mono:wght@500;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet"/>

<style>
:root {
  --bg: #07080d; --surface: #0e1018; --surface2: #151720;
  --border: rgba(255,255,255,0.06); --text: #e8eaf2; --muted: #8285a0;
  --accent: #6c63ff; --radius: 16px; --grid: rgba(255,255,255,0.03);
}

/* Light Mode Variables */
body.light-mode {
  --bg: #f4f7fa; --surface: #ffffff; --surface2: #fcfcfd;
  --border: rgba(0,0,0,0.08); --text: #1a1d23; --muted: #64748b;
  --accent: #4f46e5; --grid: rgba(0,0,0,0.05);
}

* { box-sizing: border-box; margin: 0; padding: 0; transition: background 0.3s, color 0.3s; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); padding: 20px; }

.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px; flex-wrap: wrap; }
.page-title { font-family: 'Inter', sans-serif; font-size: 22px; font-weight: 800; color: var(--accent); letter-spacing: -0.5px; }

/* Theme Toggle Button */
.theme-toggle {
    background: var(--surface2); color: var(--text); border: 1px solid var(--border);
    padding: 10px 15px; border-radius: 10px; cursor: pointer; font-size: 14px; font-weight: 600;
}

.filter-select {
    background: var(--surface2); color: var(--text); border: 1px solid var(--border);
    padding: 10px 15px; border-radius: 10px; font-weight: 600; cursor: pointer; outline: none;
}

.sec-title { font-family: 'Inter', sans-serif; font-size: 11px; letter-spacing: 1.5px; color: var(--muted); text-transform: uppercase; margin: 25px 0 12px; border-bottom: 1px solid var(--border); padding-bottom: 5px; font-weight: 700; }

.kpi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
.kpi-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
.kpi-label { font-size: 10px; font-weight: 700; color: var(--muted); text-transform: uppercase; margin-bottom: 8px; font-family: 'Inter', sans-serif; }
.kpi-val { 
    font-family: 'Roboto Mono', monospace; /* خط رسمي جدا للأرقام */
    font-size: 26px; font-weight: 700; color: var(--c); 
}

.charts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px; margin-top: 20px; }
.chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
.chart-container { position: relative; min-height: 320px; }

.checklist { flex: 1; min-width: 250px; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; max-height: 250px; overflow-y: auto; padding-right: 10px; }
.check-item { display: flex; align-items: center; gap: 8px; font-size: 12px; cursor: pointer; background: var(--surface2); padding: 8px; border-radius: 8px; border: 1px solid var(--border); }

.hidden { display: none !important; }

@media (max-width: 768px) {
    .chart-container { min-height: 500px; } 
}
</style>
</head>
<body>

<header class="header">
    <div style="display: flex; align-items: center; gap: 15px;">
        <div class="page-title">RUBYRED ANALYTICS</div>
        <button class="theme-toggle" onclick="toggleTheme()">
            <i id="themeIcon" class="fa-solid fa-sun"></i>
        </button>
    </div>
    <select class="filter-select" id="filterDropdown" onchange="applyFilter(this.value)">
        <option value="all">All Views</option>
        <option value="overview">Overview Only</option>
    </select>
</header>

<div id="overviewSection">
    <div class="sec-title">Overview Summary</div>
    <div class="kpi-grid" id="overviewKpiContainer"></div>
    <div class="charts-grid" id="overviewChartContainer"></div>
</div>

<div id="detailedSection">
    <div class="sec-title">Detailed Metrics</div>
    <div class="kpi-grid" id="detailedKpiContainer"></div>
    <div class="sec-title">Sectional Analysis</div>
    <div class="charts-grid" id="detailedChartsContainer"></div>
</div>

<div id="comparisonSection">
    <div class="sec-title">Comparison Lab</div>
    <div class="chart-card">
        <div style="display: flex; gap: 20px; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 250px;">
                <input type="text" id="compSearch" style="width:100%; margin-bottom:10px; padding:10px; background:var(--surface2); border:1px solid var(--border); color:var(--text); border-radius:8px;" placeholder="Search..." onkeyup="filterChecklist()">
                <div class="checklist" id="compareChecklist"></div>
            </div>
            <div style="flex: 1.2; min-width: 300px; height: 320px;">
                <canvas id="comparisonPieChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script>
const SHEET_ID = '1j7IFj_tylNeqwui57JU7coeB6XXj0Lt7d4yBHaqmutE';
const API_KEY  = 'AIzaSyB_dCi6NlG_jUCUY955eynfN0gF7KobQ4A';
const RANGE    = 'recruitment!A1:ZZ5';

const colors = ['#6c63ff', '#0fd493', '#f3524a', '#4594f5', '#f065b8', '#ff8c40', '#f0c040', '#a78bfa', '#00d2ff', '#fbbf24', '#f87171'];
let charts = {}, pieChart = null, masterData = [];

function toggleTheme() {
    const body = document.body;
    const icon = document.getElementById('themeIcon');
    body.classList.toggle('light-mode');
    
    if(body.classList.contains('light-mode')) {
        icon.classList.replace('fa-sun', 'fa-moon');
    } else {
        icon.classList.replace('fa-moon', 'fa-sun');
    }
    fetchData(); // لإعادة رسم الجرافات بألوان المحاور الجديدة
}

async function fetchData() {
    try {
        const res = await fetch(`https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${RANGE}?key=${API_KEY}`);
        const data = await res.json();
        if (data.values) processData(data.values);
    } catch (e) { console.error("Error loading data"); }
}

function processData(rows) {
    const row1 = rows[0] || [], row2 = rows[1] || [], row4 = rows[3] || [], row5 = rows[4] || [];
    masterData = []; 
    renderOverview(row4, row5);
    renderDetails(row1, row2);
    fillChecklist();
}

function renderOverview(labels, values) {
    const kpis = document.getElementById('overviewKpiContainer');
    const chartsBox = document.getElementById('overviewChartContainer');
    kpis.innerHTML = ''; chartsBox.innerHTML = '';
    labels.forEach((l, i) => {
        kpis.innerHTML += `<div class="kpi-card" style="--c:${colors[i%11]}"><div class="kpi-label">${l}</div><div class="kpi-val">${values[i]||0}</div></div>`;
        masterData.push({ label: l, value: parseFloat(values[i]) || 0 });
    });
    chartsBox.innerHTML = `<div class="chart-card" style="grid-column: 1 / -1"><div class="chart-container"><canvas id="canvas_overview"></canvas></div></div>`;
    renderMainChart('canvas_overview', labels, values, colors.slice(0, labels.length));
}

function renderMainChart(canvasId, labels, data, bg) {
    const ctx = document.getElementById(canvasId).getContext('2d');
    if(charts[canvasId]) charts[canvasId].destroy();
    const isMobile = window.innerWidth <= 768;
    const textColor = getComputedStyle(document.body).getPropertyValue('--muted').trim();
    const gridColor = getComputedStyle(document.body).getPropertyValue('--grid').trim();

    charts[canvasId] = new Chart(ctx, {
        type: 'bar', plugins: [ChartDataLabels],
        data: { labels: labels, datasets: [{ data: data, backgroundColor: bg, borderRadius: 6, barThickness: isMobile ? 20 : 40 }] },
        options: {
            indexAxis: isMobile ? 'y' : 'x', responsive: true, maintainAspectRatio: false,
            layout: { padding: { right: 35, top: 25, bottom: 10, left: 10 } },
            plugins: {
                legend: { display: false },
                datalabels: { 
                    anchor: 'end', align: 'end', color: getComputedStyle(document.body).getPropertyValue('--text').trim(), 
                    offset: 4, font: { family: 'Roboto Mono', weight: '700', size: 11 } 
                }
            },
            scales: {
                y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: textColor, font: { family: 'Roboto Mono', size: 10 } } },
                x: { grid: { color: gridColor }, ticks: { color: textColor, font: { family: 'Inter', weight: '600', size: 10 } } }
            }
        }
    });
}

function renderDetails(labels, values) {
    const kpis = document.getElementById('detailedKpiContainer'), chartsBox = document.getElementById('detailedChartsContainer'), dropdown = document.getElementById('filterDropdown');
    dropdown.innerHTML = '<option value="all">All Views</option><option value="overview">Overview Only</option>';
    kpis.innerHTML = ''; chartsBox.innerHTML = '';
    for (let i = 0; i < labels.length; i += 3) {
        const gLabels = labels.slice(i, i + 3), gValues = values.slice(i, i + 3);
        const groupName = gLabels[0].split(' ')[0], groupID = `group_${groupName.toLowerCase()}_${i}`;
        dropdown.innerHTML += `<option value="${groupID}">${groupName}</option>`;
        gLabels.forEach((lbl, idx) => {
            kpis.innerHTML += `<div class="kpi-card detail-item ${groupID}" style="--c:${colors[(i+idx)%11]}"><div class="kpi-label">${lbl}</div><div class="kpi-val">${gValues[idx]||0}</div></div>`;
            masterData.push({ label: lbl, value: parseFloat(gValues[idx]) || 0 });
        });
        chartsBox.innerHTML += `<div class="chart-card detail-chart" id="card_${groupID}"><div class="chart-container"><canvas id="canvas_${groupID}"></canvas></div></div>`;
        setTimeout(() => renderSimpleChart(`canvas_${groupID}`, gLabels, gValues, colors.slice(i%11, (i%11)+3)), 150);
    }
}

function renderSimpleChart(canvasId, labels, data, bg) {
    const ctx = document.getElementById(canvasId).getContext('2d');
    const gridColor = getComputedStyle(document.body).getPropertyValue('--grid').trim();
    if(charts[canvasId]) charts[canvasId].destroy();
    charts[canvasId] = new Chart(ctx, {
        type: 'bar', plugins: [ChartDataLabels],
        data: { labels: labels, datasets: [{ data: data, backgroundColor: bg, borderRadius: 6, barThickness: 35 }] },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { 
                legend: { display: false }, 
                datalabels: { anchor: 'end', align: 'end', color: getComputedStyle(document.body).getPropertyValue('--text').trim(), font: { family: 'Roboto Mono', weight: '700', size: 11 } } 
            },
            scales: {
                y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: '#8285a0', font: { family: 'Roboto Mono', size: 10 } } },
                x: { grid: { display: false }, ticks: { color: '#8285a0', font: { family: 'Inter', weight: '600', size: 10 } } }
            }
        }
    });
}

function fillChecklist() {
    const list = document.getElementById('compareChecklist');
    list.innerHTML = masterData.map((d, i) => `<label class="check-item"><input type="checkbox" value="${i}" onchange="updatePie()"> <span>${d.label}</span></label>`).join('');
}

function filterChecklist() {
    const q = document.getElementById('compSearch').value.toLowerCase();
    document.querySelectorAll('.check-item').forEach(el => el.style.display = el.innerText.toLowerCase().includes(q) ? 'flex' : 'none');
}

function updatePie() {
    const checked = Array.from(document.querySelectorAll('#compareChecklist input:checked')).map(el => el.value);
    const ctx = document.getElementById('comparisonPieChart').getContext('2d');
    if (checked.length === 0) { if(pieChart) pieChart.destroy(); return; }
    if (pieChart) pieChart.destroy();
    pieChart = new Chart(ctx, {
        type: 'doughnut', plugins: [ChartDataLabels],
        data: { labels: checked.map(i => masterData[i].label), datasets: [{ data: checked.map(i => masterData[i].value), backgroundColor: checked.map(i => colors[i % 11]) }] },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { 
                legend: { position: 'bottom', labels: { color: '#8285a0', font: { family: 'Inter', size: 10 } } }, 
                datalabels: { color: '#fff', font: { family: 'Roboto Mono', weight: '700' }, formatter: (v, c) => ((v * 100) / c.chart.data.datasets[0].data.reduce((a, b) => a + b, 0)).toFixed(1) + "%" } 
            }
        }
    });
}

function applyFilter(val) {
    const ov = document.getElementById('overviewSection'), det = document.getElementById('detailedSection');
    if (val === 'overview') { ov.classList.remove('hidden'); det.classList.add('hidden'); }
    else if (val === 'all') { ov.classList.remove('hidden'); det.classList.remove('hidden'); document.querySelectorAll('.detail-item, .detail-chart').forEach(e => e.classList.remove('hidden')); }
    else { ov.classList.add('hidden'); det.classList.remove('hidden'); document.querySelectorAll('.detail-item').forEach(e => e.classList.toggle('hidden', !e.classList.contains(val))); document.querySelectorAll('.detail-chart').forEach(e => e.classList.toggle('hidden', e.id !== `card_${val}`)); }
}

window.addEventListener('resize', fetchData);
fetchData();
</script>
</body>
</html>
